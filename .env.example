# Copy this file to .env for local dev, and set these in Vercel Project Settings
# > Environment Variables.

# --- Database (Prisma, optional on serverless) ---
# Local dev (SQLite file):
DATABASE_URL="file:/home/z/my-project/db/custom.db"
# On Vercel, set this to a temp file path. The app runs fully; chat history /
# feedback / analytics just won't survive cold restarts (acceptable on free tier).
DATABASE_URL="file:/tmp/visit-rwanda.db"
# For real persistence, use a free Turso (libSQL) database. See DEPLOY.md.

# --- AI: Google Gemini 2.0 Flash (FREE tier: 15 req/min, 1500 req/day) ---
# Get a free API key at https://aistudio.google.com/apikey (no credit card needed).
GEMINI_API_KEY=""
# Optional: override the model (defaults to gemini-2.0-flash).
# GEMINI_MODEL="gemini-2.0-flash"
