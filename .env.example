# Copy this file to .env for local dev, and set these in Vercel Project Settings > Environment Variables.

# --- Database (Prisma) ---
# Local dev (SQLite file):
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# On Vercel, SQLite does not persist. Two options:
#   (A) Quick demo (no persistence): set this to a temp file path.
#       DATABASE_URL="file:/tmp/visit-rwanda.db"
#       The app runs fully; chat history / feedback / analytics just won't survive restarts.
#   (B) Real persistence (recommended): use a free Turso (libSQL) database and set:
#       DATABASE_URL="libsql://your-db.turso.io"
#       DATABASE_AUTH_TOKEN="your-turso-token"
#       This requires the small Turso migration noted in DEPLOY.md.

# --- ZAI SDK (AI concierge + image search + web search) ---
# The z-ai-web-dev-sdk reads credentials from a config file locally.
# On Vercel you must provide these as env vars instead.
# Create them with the values from your local /etc/.z-ai-config (or your ZAI account):
ZAI_API_KEY=""
ZAI_BASE_URL=""
ZAI_TOKEN=""
ZAI_USER_ID=""
